  "keyFeatures": [
    "Vertical Slice Architecture with self-contained feature slices",
    "Real-time price streaming via WebSockets (Fintacharts l1-subscription)",
    "In-memory event bus for reactive background service orchestration",
    "Two-layer caching: ConcurrentDictionary (L1) + PostgreSQL UPSERT (L2)",
    "Automatic token management with thread-safe refresh logic",
    "Docker Compose deployment with PostgreSQL 16",
    "OpenAPI/Swagger UI at /swagger",
    "Graceful WebSocket session management with reactive reconnection"
  ],
  "publicApiSurface": [
    "GET /api/assets",
    "GET /api/prices",
    "GET /api/prices?ids={guid1}&ids={guid2}",
    "GET /api/assets/{id}/history?barsCount={n}"
  ]
